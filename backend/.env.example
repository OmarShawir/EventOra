DB_HOST=localhost
DB_PORT=3306
DB_NAME=eventora
DB_USER=root
DB_PASS=

JWT_SECRET=change_this_to_a_long_random_string_before_deploying
JWT_EXPIRY_SECONDS=86400

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email is sent via the Resend HTTP API (https://resend.com) rather than
# SMTP, because Railway blocks outbound SMTP ports. Get an API key from the
# Resend dashboard. MAIL_FROM must be a Resend-verified sender; until you
# verify a domain, Resend only allows the shared onboarding@resend.dev
# address (which can only deliver to your own Resend account email).
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=EventOra <onboarding@resend.dev>

FRONTEND_URL=http://localhost:5173
# Public URL this backend is reachable at — used to build absolute links
# (e.g. uploaded image URLs). Set to the Railway-issued domain in production.
APP_URL=http://localhost:8080

GOOGLE_CLIENT_ID=your_google_oauth_client_id

STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Secret key required as ?key=... on /migrate.php to run schema migrations
# and reseed demo data. Generate a long random value and never commit it.
MIGRATE_SECRET=change_this_to_a_long_random_string